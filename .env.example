# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Infrastructure (defaults match deploy/docker-compose.yml)
REQRADAR_NATS_URL=nats://localhost:4222
REQRADAR_POSTGRES_DSN=postgres://reqradar:reqradar@localhost:5432/reqradar?sslmode=disable
REQRADAR_LOG_LEVEL=info

# Secrets
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Fit score (free-tier Gemini, no credit card — get a key at https://aistudio.google.com/apikey).
# Empty = fit scoring returns "not configured"; everything else still works.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash   # optional override

# Reddit (optional collector — see WATCHLIST.md for ToS constraints)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# GitHub token for the historical backfill (commits API rate limits).
# Any classic/fine-grained PAT with public read works; `gh auth token` prints one.
GITHUB_TOKEN=
